{
  "name": "stitcher",
  "version": "1.0.0",
  "description": "Bitespeed Identity Reconciliation Service — links customer contacts across purchases",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "render-build": "npm install && npm run build",
    "start": "node dist/index.js",
    "test": "vitest run",
